-- 自動攻擊+瞬移功能（更新後：選全場連鎖數最多的目標）
autoAttackTPBtn.MouseButton1Click:Connect(function()
    autoAttackTPEnabled = not autoAttackTPEnabled
    updateButtonText(autoAttackTPBtn, autoAttackTPEnabled, "自動攻擊+瞬移")
    
    if autoAttackTPEnabled then
        spawn(function()
            local wasDead = false

            while autoAttackTPEnabled do
                local char = LocalPlayer.Character
                local humanoid = char and char:FindFirstChild("Humanoid")

                -- 偵測死亡：Humanoid不存在或Health為0
                local isDead = not humanoid or humanoid.Health <= 0

                if isDead then
                    if not wasDead then
                        wasDead = true
                    end
                else
                    -- 剛從死亡復活
                    if wasDead then
                        wasDead = false
                        wait(1) -- 等待復活動畫/重生完成
                        if autoAttackTPEnabled and invisSpeedEnabled then
                            activateInvisSpeed()
                            wait(0.5) -- 等隱形加速生效
                        end
                    end

                    local target = findPlayerCluster()
                    if target then
                        teleportToPlayer(target)
                        wait(0.1)
                        attackPlayer(target)
                    end
                end

                wait(0.6)
            end
        end)
    end
end)

