-- Server Hop功能 (鎖定12-14人伺服器)
local function serverHop()
    local gameId = game.PlaceId
    local success, result = pcall(function()
        local servers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. gameId .. "/servers/Public?sortOrder=Asc&limit=100"))
        
        if servers.data then
            local validServers = {}
            for _, server in ipairs(servers.data) do
                if server.id ~= game.JobId and server.playing >= 12 and server.playing <= 14 then
                    table.insert(validServers, server.id)
                end
            end
            
            if #validServers > 0 then
                local randomServer = validServers[math.random(1, #validServers)]
                TeleportService:TeleportToPlaceInstance(gameId, randomServer, LocalPlayer)
                return true
            else
                local moreServers = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. gameId .. "/servers/Public?sortOrder=Desc&limit=100"))
                if moreServers.data then
                    for _, server in ipairs(moreServers.data) do
                        if server.id ~= game.JobId and server.playing >= 12 and server.playing <= 14 then
                            table.insert(validServers, server.id)
                        end
                    end
                    
                    if #validServers > 0 then
                        local randomServer = validServers[math.random(1, #validServers)]
                        TeleportService:TeleportToPlaceInstance(gameId, randomServer, LocalPlayer)
                        return true
                    end
                end
            end
        end
        return false
    end)
    
    if not success or not result then
        print("找不到12-14人的伺服器，使用普通跳轉")
        TeleportService:Teleport(gameId, LocalPlayer)
    end
end

-- 尋找最近玩家的函數
local function findClosestPlayer()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPosition = myChar.HumanoidRootPart.Position
    local closestPlayer = nil
    local closestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - myPosition).Magnitude
            if distance < closestDistance then
                closestDistance = distance
                closestPlayer = player
            end
        end
    end
    
    return closestPlayer
end

-- 尋找15單位內最近玩家的函數
local function findClosestPlayerInRange(range)
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPosition = myChar.HumanoidRootPart.Position
    local closestPlayer = nil
    local closestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - myPosition).Magnitude
            if distance <= range and distance < closestDistance then
                closestDistance = distance
                closestPlayer = player
            end
        end
    end
    
    return closestPlayer
end

-- =====================================================
-- 更新後的連鎖判定：找全場連鎖數最多的目標
-- 保留原本的位置範圍限制（Y <= 250，距原點 <= 1000）
-- =====================================================
local function findPlayerCluster()
    -- 先收集所有符合範圍限制的玩家
    local players = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local playerPos = player.Character.HumanoidRootPart.Position
            local distanceFromOrigin = (playerPos - Vector3.new(0, 0, 0)).Magnitude
            if playerPos.Y <= 250 and distanceFromOrigin <= 1000 then
                table.insert(players, player)
            end
        end
    end

    if #players == 0 then return nil end

    -- BFS 計算從某個玩家出發，連鎖能打到的總人數
    local function countChainHits(startPlayer)
        local visited = {}
        local queue = {startPlayer}
        visited[startPlayer] = true
        local count = 0

        while #queue > 0 do
            local current = table.remove(queue, 1)
            count = count + 1
            local currentPos = current.Character.HumanoidRootPart.Position

            for _, other in pairs(players) do
                if not visited[other] then
                    local dist = (other.Character.HumanoidRootPart.Position - currentPos).Magnitude
                    if dist <= 20 then
                        visited[other] = true
                        table.insert(queue, other)
                    end
                end
            end
        end

        return count
    end

    -- 直接從全場所有符合條件的玩家中，找連鎖數最多的目標
    local bestPlayer = nil
    local maxChain = 0

    for _, player in pairs(players) do
        local chainCount = countChainHits(player)
        if chainCount > maxChain then
            maxChain = chainCount
            bestPlayer = player
        end
    end

    return bestPlayer
end

-- 設定玩家速度
local function setPlayerSpeed(speed)
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("Humanoid") then
        myChar.Humanoid.WalkSpeed = speed
    end
end

-- 瞬移到玩家
local function teleportToPlayer(targetPlayer)
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") and 
       targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        myChar.HumanoidRootPart.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame + Vector3.new(2, 0, 2)
    end
end

-- 攻擊玩家
local function attackPlayer(targetPlayer)
    if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Right Arm") then
        local args = {
            [1] = targetPlayer.Character:FindFirstChild("Right Arm")
        }
        ReplicatedStorage.GeneralHit:FireServer(unpack(args))
    end
end

-- 隱形+加速序列（獨立函數）
local function activateInvisSpeed()
    spawn(function()
        if workspace.Lobby:FindFirstChild("Ghost") and workspace.Lobby.Ghost:FindFirstChild("ClickDetector") then
            fireclickdetector(workspace.Lobby.Ghost.ClickDetector)
            wait(0.1)
        end
        
        if ReplicatedStorage:FindFirstChild("Ghostinvisibilityactivated") then
            ReplicatedStorage.Ghostinvisibilityactivated:FireServer()
            wait(0.1)
        end
        
        if workspace.Lobby:FindFirstChild("Chain") and workspace.Lobby.Chain:FindFirstChild("ClickDetector") then
            fireclickdetector(workspace.Lobby.Chain.ClickDetector)
            wait(0.1)
        end
        
        setPlayerSpeed(50)
    end)
end

